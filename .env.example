# PerfectBlue AI Runtime Configuration
# Copy hoặc đổi tên file này thành `.env` rồi điền khóa API của bạn vào đây.

GEMINI_API_KEY=your_gemini_api_key_here

# Optional comma-separated Gemini keys for rotation.
GEMINI_API_KEYS=
OPENROUTER_API_KEY=

# Runtime is local-only by default. Set a token before binding to a LAN address.
PERFECTBLUE_HOST=127.0.0.1
PERFECTBLUE_PORT=7770
PERFECTBLUE_RUNTIME_TOKEN=
PERFECTBLUE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Arbitrary Python execution is disabled by default.
PERFECTBLUE_ENABLE_PYTHON_TOOL=false

# Vite dashboard connection settings (must be present when Vite starts).
VITE_PERFECTBLUE_RUNTIME_URL=http://127.0.0.1:7770
VITE_PERFECTBLUE_RUNTIME_TOKEN=
VITE_CLAW3D_URL=http://127.0.0.1:3000
